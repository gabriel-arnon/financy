# URL base do backend FastAPI.
# Local pode usar http://127.0.0.1:8000.
# Preview/Production devem definir uma URL https real; o build remoto falha sem esta variavel.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Reservado para a fase de autenticacao.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional owner-only Open Finance UI gate. Backend authorization remains authoritative.
NEXT_PUBLIC_OPEN_FINANCE_ENABLED=false
NEXT_PUBLIC_OPEN_FINANCE_OWNER_USER_ID=
