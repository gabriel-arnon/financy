APP_NAME=Financy API
APP_ENV=local
DEV_USER_ID=00000000-0000-4000-8000-000000000001
UPLOAD_STORAGE_PATH=.uploads
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql://financy_dev:financy_dev_local@localhost:5432/financy_dev
TEST_DATABASE_URL=postgresql://financy_dev:financy_dev_local@localhost:5432/financy_dev_test
STORAGE_BACKEND=json
AUTH_PROVIDER=supabase
AUTH_REQUIRED=false
AUTH_DEV_BYPASS=true
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_AUDIENCE=
JWT_SECRET=change-me-local-only
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PRIVATE_FILES_ENABLED=true
PRIVATE_FILES_BACKEND=local
# Alias supported for Supabase validation: FILE_STORAGE_PROVIDER=local|supabase
PRIVATE_FILES_BUCKET=financy-private
# Alias supported for Supabase validation: SUPABASE_STORAGE_BUCKET=financy-private
PRIVATE_FILES_MAX_SIZE_BYTES=10485760
PRIVATE_FILES_SIGNED_URL_TTL_SECONDS=300
# Alias supported for Supabase validation: SIGNED_URL_TTL_SECONDS=300
PRIVATE_FILES_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
PRIVATE_FILES_SCAN_PROVIDER=mock
# Alias supported for Supabase validation: FILE_SCAN_PROVIDER=mock
PRIVATE_FILES_ORPHAN_RETENTION_HOURS=24
INVITATION_ACCEPT_RATE_LIMIT_ENABLED=true
INVITATION_ACCEPT_RATE_LIMIT_MAX_ATTEMPTS=5
INVITATION_ACCEPT_RATE_LIMIT_WINDOW_SECONDS=900

# Optional AI-assisted import fallback for unknown/low-confidence PDFs
AI_IMPORT_ENABLED=false
AI_IMPORT_PROVIDER=openai-compatible
AI_IMPORT_BASE_URL=https://api.openai.com/v1
AI_IMPORT_API_KEY=
AI_IMPORT_MODEL=gpt-4o-mini
AI_IMPORT_TIMEOUT_SECONDS=45

# Optional owner-only Open Finance integration via Meu Pluggy/Pluggy.
OPEN_FINANCE_ENABLED=false
OPEN_FINANCE_OWNER_USER_ID=
PLUGGY_BASE_URL=https://api.pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_WEBHOOK_SECRET=
PLUGGY_SYNC_LOOKBACK_DAYS=370
PLUGGY_API_TIMEOUT_SECONDS=30
