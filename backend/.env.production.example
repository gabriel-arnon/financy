APP_NAME=Financy API
APP_ENV=production

# Auth must be required in production. DEV_USER_ID is kept only as a migration/source reference.
AUTH_PROVIDER=supabase
AUTH_REQUIRED=true
AUTH_DEV_BYPASS=false
DEV_USER_ID=00000000-0000-4000-8000-000000000001

# Supabase/Auth
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_AUDIENCE=authenticated
JWT_SECRET=REPLACE_WITH_SUPABASE_JWT_SECRET

# Database
STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://postgres:REPLACE_WITH_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# API access
CORS_ORIGINS=https://financy-flame.vercel.app

# Uploads/storage
UPLOAD_STORAGE_PATH=/app/.uploads
PRIVATE_FILES_ENABLED=true
PRIVATE_FILES_BACKEND=supabase
# Alias accepted by the backend: FILE_STORAGE_PROVIDER=supabase
PRIVATE_FILES_BUCKET=private-files
# Alias accepted by the backend: SUPABASE_STORAGE_BUCKET=private-files
PRIVATE_FILES_MAX_SIZE_BYTES=10485760
PRIVATE_FILES_SIGNED_URL_TTL_SECONDS=300
# Alias accepted by the backend: SIGNED_URL_TTL_SECONDS=300
PRIVATE_FILES_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
PRIVATE_FILES_SCAN_PROVIDER=REPLACE_WITH_SCAN_PROVIDER
# Alias accepted by the backend: FILE_SCAN_PROVIDER=REPLACE_WITH_SCAN_PROVIDER
PRIVATE_FILES_ORPHAN_RETENTION_HOURS=24

# Migration/admin only. Do not expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
